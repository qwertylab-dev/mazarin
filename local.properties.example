# Template for local.properties.
# Copy this file to local.properties and fill in your real values.
# local.properties is gitignored — do not commit your real values.

# Path to your Android SDK installation.
# Linux/macOS: typically /home/<user>/Android/Sdk or /Users/<user>/Library/Android/sdk
# Windows: typically C:\\Users\\<user>\\AppData\\Local\\Android\\Sdk
sdk.dir=/path/to/Android/Sdk

# Google Books API key — used by BookAPI to enrich Project Gutenberg metadata
# with extras (covers, descriptions). Get one at https://console.cloud.google.com/
# under APIs & Services → Credentials. Restrict it to the Books API.
# If left empty or set to "null", the app builds and runs but extra metadata is unavailable.
GOOGLE_API_KEY=
